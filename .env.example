# Application
NODE_ENV=production
DOMAIN=complextest.spidmax.win

# Database (PostgreSQL)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=complextest
POSTGRES_PASSWORD=changeme
POSTGRES_DB=complextest

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Backend
BACKEND_PORT=3001

# Frontend
NEXT_PUBLIC_API_URL=https://api.complextest.spidmax.win
NEXT_PUBLIC_WS_URL=wss://ws.complextest.spidmax.win
